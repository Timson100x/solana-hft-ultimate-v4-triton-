# =============================================================
# Solana HFT Ultimate v4.2 - Triton One Edition
# .env.example - Timmy / Düsseldorf
# NIEMALS diese Datei mit echten Werten committen!
# =============================================================

# --- TRITON ONE (Dragon's Mouth gRPC) ---
TRITON_GRPC_URL=timmys-mainnet-e441.rpcpool.com:443
TRITON_X_TOKEN=DEIN_TRITON_TOKEN_HIER
TRITON_HTTP_URL=https://timmys-mainnet-e441.rpcpool.com/DEIN_TRITON_TOKEN_HIER
TRITON_WS_URL=wss://timmys-mainnet-e441.rpcpool.com/DEIN_TRITON_TOKEN_HIER/whirligig

# --- JITO MEV ---
JITO_BLOCK_ENGINE_URL=frankfurt.mainnet.block-engine.jito.wtf
JITO_TIP_LAMPORTS=10000
JITO_MAX_BUNDLE_SIZE=5

# --- WALLET ---
WALLET_PRIVATE_KEY=DEIN_BASE58_PRIVATE_KEY_HIER
WALLET_PUBLIC_KEY=DEIN_PUBLIC_KEY_HIER

# --- HELIUS (Fallback RPC) ---
HELIUS_API_KEY=DEIN_HELIUS_KEY_HIER
HELIUS_RPC_URL=https://mainnet.helius-rpc.com/?api-key=DEIN_HELIUS_KEY_HIER

# --- RIG / GOAT AI ---
XAI_API_KEY=DEIN_XAI_GROK_KEY_HIER
OPENAI_API_KEY=DEIN_OPENAI_KEY_OPTIONAL

# --- TELEGRAM ALERTS ---
TELEGRAM_BOT_TOKEN=DEIN_TELEGRAM_TOKEN_HIER
TELEGRAM_CHAT_ID=DEINE_CHAT_ID_HIER

# --- TRADING PARAMETER ---
MAX_SOL_PER_TRADE=0.1
SLIPPAGE_BPS=500
MIN_LIQUIDITY_SOL=5.0
TAKE_PROFIT_PCT=50
STOP_LOSS_PCT=20
SHARDS=4
KEEPALIVE_SECS=30
MAX_MESSAGE_SIZE_MB=64

# --- AWS (für CI/CD) ---
AWS_REGION=eu-central-1
AWS_INSTANCE_TYPE=t4g.small

# --- RUST ---
RUST_LOG=info
RUST_BACKTRACE=1
